# This file is for the Node.js backend.
# Do NOT commit your actual .env file to GitHub. 

# 1. CORS Security (Optional but recommended)
# Put your Vercel/Netlify frontend URL here so only your website can access this backend.
# Leave blank to allow all connections.
FRONTEND_URL=https://my-instasave.vercel.app

# 2. Instagram Scraper API (RapidAPI)
# Go to rapidapi.com, subscribe to an Instagram Downloader API, and put your API key here.
RAPIDAPI_KEY=your_rapid_api_key_here

# (Optional) If you choose an API with a different host, change it here:
# RAPIDAPI_HOST=instagram-downloader-download-instagram-videos-stories.p.rapidapi.com
